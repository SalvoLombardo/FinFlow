# Database
DATABASE_URL=postgresql+asyncpg://finflow:finflow@localhost:5432/finflow_db

# Security
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENCRYPTION_KEY=changeme-generate-with-fernet-key-gen

# AWS (used in production, not locally)
AWS_REGION=eu-west-1
AWS_SNS_TOPIC_ARN=
AWS_SQS_PROJECTIONS_URL=
AWS_SQS_AI_ANALYSIS_URL=
AWS_SQS_NOTIFICATIONS_URL=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_AUDIT_TOPIC=finflow.audit

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# S3 audit archive
S3_AUDIT_BUCKET=
