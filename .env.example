# Frontend (used to scope CORS — set to the CloudFront URL in production)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://finflow:finflow@localhost:5432/finflow_db
# Set to "true" only where Postgres is reached over the public internet with TLS
# enabled server-side (Terraform sets this on the API/consumer Lambdas — see
# PRODUCTION_READINESS.md "public Postgres" finding). Encrypts the channel against
# a self-signed cert (no private CA in this $0 setup) without verifying identity —
# stops passive credential/data sniffing. Leave unset locally/Docker/CI: that
# Postgres has no TLS configured and the connection would fail to negotiate it.
DATABASE_SSL_REQUIRE=
# Timeout in seconds to establish the TCP connection to Postgres (default: 5).
# Timeout in seconds for any single SQL command / query (default: 15).
# Override in production if Lambda timeout budget differs significantly.
DB_CONNECT_TIMEOUT=5
DB_STATEMENT_TIMEOUT=15

# Security
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENCRYPTION_KEY=changeme-generate-with-fernet-key-gen

# AWS (used in production, not locally)
AWS_REGION=eu-west-1
# Set by Terraform on the API/consumer Lambdas (e.g. /finflow/prod). When present,
# DATABASE_URL/SECRET_KEY/ENCRYPTION_KEY are fetched from SSM Parameter Store at
# cold start instead of via plaintext env vars — see app/core/secrets.py.
SSM_PARAMETER_PREFIX=
AWS_SNS_TOPIC_ARN=
AWS_SQS_PROJECTIONS_URL=
AWS_SQS_AI_ANALYSIS_URL=
AWS_SQS_NOTIFICATIONS_URL=
AWS_NOTIFICATION_TOPIC_ARN=    # SNS topic with email subscription for goal alerts

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_AUDIT_TOPIC=finflow.audit

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# S3 audit archive
S3_AUDIT_BUCKET=

# AI rate limiting (requests per user per day)
AI_DAILY_RATE_LIMIT=10
